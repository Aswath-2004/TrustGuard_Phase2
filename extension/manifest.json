{
  "manifest_version": 3,
  "name": "TrustGuard AI Verifier",
  "version": "2.4",
  "description": "One-click verification of AI responses for hallucinations and PII",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://trustguard-phase2.onrender.com/*",
    "https://trust-guard-phase2.vercel.app/*",
    "https://trustguard.vercel.app/*",
    "https://*.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "TrustGuard AI Verifier",
    "default_popup": "popup.html"
  }
}