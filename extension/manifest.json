{
  "manifest_version": 3,
  "name": "TrustGuard AI Verifier",
  "version": "2.2",
  "description": "One-click verification of AI responses for hallucinations and PII",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5173/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "TrustGuard AI Verifier",
    "default_popup": "popup.html"
  }
}
